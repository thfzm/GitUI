<Window x:Class="GitUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:vm="clr-namespace:GitUI.ViewModels"
        xmlns:views="clr-namespace:GitUI.Views"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="GitUI"
        Height="800" Width="1240"
        MinHeight="540" MinWidth="900"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop"
        StateChanged="Window_StateChanged">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CreateRepoViewModel}">
            <views:CreateRepoView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RepoDetailViewModel}">
            <views:RepoDetailView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CommandPaletteViewModel}">
            <views:CommandPalette/>
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding OpenCommandPaletteCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding ShowCreateRepoCommand}"/>
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding RefreshReposCommand}"/>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding ToggleThemeCommand}"/>
    </Window.InputBindings>

    <Grid>
        <!-- Tray icon (icon is assigned in code-behind) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="GitUI"
                        TrayMouseDoubleClick="TrayIcon_DoubleClick"
                        Visibility="Collapsed">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="GitUI 열기" Click="ShowFromTray_Click"/>
                    <Separator/>
                    <MenuItem Header="종료" Click="ExitFromTray_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Login screen -->
        <ContentControl Content="{Binding Login}"
                        Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVis}}"/>

        <!-- Main shell -->
        <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="GitUI" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                        <Button Command="{Binding OpenCommandPaletteCommand}"
                                Background="Transparent" BorderThickness="1"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                Margin="16,0,0,0" Padding="10,4"
                                ToolTip="명령 팔레트 (Ctrl+P)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" Margin="0,0,6,0" FontSize="11"/>
                                <TextBlock Text="검색 / 명령" Opacity="0.6" FontSize="11"/>
                                <TextBlock Text="Ctrl+P" Opacity="0.4" FontSize="10" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding ToggleThemeCommand}"
                                Background="Transparent" BorderThickness="0"
                                ToolTip="테마 전환 (Ctrl+T)" Margin="0,0,8,0">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="🌙"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="False">
                                                <Setter Property="Text" Value="☀️"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0"
                                Visibility="{Binding AvatarUrl, Converter={StaticResource NotNullToVis}}">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="{Binding Username}" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding AuthMethodLabel}" FontSize="10" Opacity="0.6"/>
                        </StackPanel>
                        <Button Command="{Binding LogoutCommand}" Content="로그아웃"
                                Background="Transparent" BorderThickness="0" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Command="{Binding ShowCreateRepoCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Margin="12,12,12,8" Height="36"
                                ToolTip="Ctrl+N">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="새 리포지토리" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Grid Grid.Row="1" Margin="12,0,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     ui:ControlHelper.PlaceholderText="리포 검색..."/>
                            <Button Grid.Column="1" Command="{Binding RefreshReposCommand}"
                                    ToolTip="새로고침 (Ctrl+R)" Margin="6,0,0,0"
                                    Background="Transparent" BorderThickness="0">
                                <TextBlock Text="↻" FontSize="14"/>
                            </Button>
                        </Grid>

                        <Grid Grid.Row="2" Margin="12,0,12,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="내 리포지토리"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding MultiSelectMode}"
                                          Background="Transparent" BorderThickness="0"
                                          Padding="6,2" FontSize="11"
                                          ToolTip="다중 선택 모드">
                                <TextBlock Text="☑"/>
                            </ToggleButton>
                        </Grid>

                        <!-- Bulk action bar -->
                        <Border Grid.Row="3" Margin="12,4,12,4" Padding="8,4"
                                CornerRadius="6"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                Visibility="{Binding MultiSelectMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" FontSize="11" Margin="0,0,6,0">
                                    <Run Text="{Binding SelectedRepos.Count, Mode=OneWay}"/><Run Text="개 선택"/>
                                </TextBlock>
                                <Button Command="{Binding BulkArchiveCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="아카이브" Padding="4,2">
                                    <TextBlock Text="📦" FontSize="13"/>
                                </Button>
                                <Button Command="{Binding BulkDeleteCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="삭제" Padding="4,2">
                                    <TextBlock Text="🗑" FontSize="13"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <ListBox Grid.Row="4"
                                 x:Name="ReposListBox"
                                 ItemsSource="{Binding FilteredRepos}"
                                 SelectedItem="{Binding SelectedRepo}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionMode="{Binding MultiSelectMode, Converter={StaticResource MultiSelectModeConverter}}"
                                 SelectionChanged="ReposListBox_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="6,2"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" CornerRadius="6">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                                <Border Margin="6,1,0,0" Padding="5,1" CornerRadius="6"
                                                        Background="{Binding Private, Converter={StaticResource PrivateBadge}}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="#222">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Public"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Private}" Value="True">
                                                                        <Setter Property="Text" Value="Private"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}"
                                                       Visibility="{Binding Description, Converter={StaticResource NotNullToVis}}"
                                                       Opacity="0.55" FontSize="11"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Hint footer -->
                        <Border Grid.Row="5" Padding="12,8"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,1,0,0">
                            <TextBlock FontSize="10" Opacity="0.55" TextWrapping="Wrap"
                                       Text="💡 폴더를 창에 끌어다 놓으면 새 리포지토리로 즉시 업로드"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Content area -->
                <ContentControl Grid.Column="1" Content="{Binding CurrentContent}"/>
            </Grid>

            <!-- Drop overlay -->
            <Border x:Name="DropOverlay"
                    Grid.RowSpan="2"
                    Background="#CC000000"
                    Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📂" FontSize="80" HorizontalAlignment="Center"/>
                    <TextBlock Text="폴더를 드롭하면 새 리포지토리로 만듭니다"
                               FontSize="20" FontWeight="SemiBold" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

            <!-- Busy overlay -->
            <Border Grid.RowSpan="2"
                    Background="#88000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <ui:ProgressRing IsActive="True" Width="48" Height="48"/>
            </Border>
        </Grid>

        <!-- Command palette overlay -->
        <ContentControl Content="{Binding CommandPalette}"
                        Visibility="{Binding CommandPalette, Converter={StaticResource NotNullToVis}}"/>
    </Grid>
</Window>
