<Window x:Class="GitUI.Views.Dialogs.CreateRepoFromFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="폴더로 새 리포지토리 만들기"
        SizeToContent="Height"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <StackPanel Margin="24">
        <TextBlock Text="📁 → 🐙" FontSize="36" HorizontalAlignment="Center"/>
        <TextBlock Text="이 폴더를 새 GitHub 리포지토리로 업로드합니다."
                   TextAlignment="Center" Opacity="0.6" Margin="0,4,0,16"/>

        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                CornerRadius="6" Padding="10,8" Margin="0,0,0,16">
            <TextBlock x:Name="FolderPathLabel" FontFamily="Consolas, Courier New" FontSize="12"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <TextBlock Text="리포지토리 이름 *" Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" Margin="0,0,0,12"
                 ui:ControlHelper.PlaceholderText="my-awesome-repo"/>

        <TextBlock Text="설명" Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="DescBox" Margin="0,0,0,12"
                 ui:ControlHelper.PlaceholderText="(선택)"/>

        <CheckBox x:Name="PrivateCheck" Content="비공개 리포지토리 (Private)" Margin="0,0,0,4"/>
        <CheckBox x:Name="GitignoreCheck" Content="로컬 .gitignore 적용" IsChecked="True" Margin="0,0,0,16"/>

        <ProgressBar x:Name="Progress" Height="6" Maximum="100" Margin="0,0,0,4" Visibility="Collapsed"/>
        <TextBlock x:Name="StatusLabel" Opacity="0.7" FontSize="12" Margin="0,0,0,12"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="CancelButton" Click="Cancel_Click"
                    Content="취소" Width="100" Height="36" Margin="0,0,8,0"/>
            <Button Grid.Column="2" x:Name="CreateButton" Click="Create_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="생성 + 업로드" Width="140" Height="36"/>
        </Grid>
    </StackPanel>
</Window>
