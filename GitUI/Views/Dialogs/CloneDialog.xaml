<Window x:Class="GitUI.Views.Dialogs.CloneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="리포지토리 클론"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <StackPanel Margin="24">
        <TextBlock Text="📥" FontSize="36" HorizontalAlignment="Center"/>
        <TextBlock x:Name="RepoLabel" TextAlignment="Center" Opacity="0.7" Margin="0,4,0,16"
                   FontFamily="Consolas, Courier New" FontSize="13"/>

        <TextBlock Text="로컬 경로 *" Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PathBox" Grid.Column="0"
                     ui:ControlHelper.PlaceholderText="C:\path\to\folder"/>
            <Button Grid.Column="1" x:Name="BrowseButton"
                    Click="Browse_Click" Content="찾아보기..."
                    Margin="8,0,0,0"/>
        </Grid>

        <TextBlock Text="브랜치" Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
        <ComboBox x:Name="BranchBox" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

        <CheckBox x:Name="RecursiveCheck" Content="서브모듈도 함께 (recursive)" Margin="0,0,0,8"/>
        <CheckBox x:Name="OpenAfterCheck" Content="완료 후 폴더 열기" IsChecked="True" Margin="0,0,0,16"/>

        <ProgressBar x:Name="Progress" Height="6" Maximum="100" Margin="0,0,0,4" Visibility="Collapsed"/>
        <TextBlock x:Name="StatusLabel" Opacity="0.75" FontSize="11" Margin="0,0,0,12"
                   FontFamily="Consolas, Courier New" TextTrimming="CharacterEllipsis"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="CancelButton" Click="Cancel_Click"
                    Content="취소" Width="90" Height="36" Margin="0,0,8,0"/>
            <Button Grid.Column="2" x:Name="OpenButton" Click="OpenFolder_Click"
                    Content="폴더 열기" Width="100" Height="36" Margin="0,0,8,0"
                    Visibility="Collapsed"/>
            <Button Grid.Column="3" x:Name="CloneButton" Click="Clone_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="클론" Width="90" Height="36"/>
        </Grid>
    </StackPanel>
</Window>
