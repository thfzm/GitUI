<UserControl x:Class="GitUI.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:vm="clr-namespace:GitUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:SearchViewModel}"
             mc:Ignorable="d">
    <Grid Margin="32,24,32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="🔍 외부 리포지토리 검색"
                       FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Text="GitHub의 모든 공개 리포를 검색하고 바로 클론할 수 있습니다."
                       Opacity="0.6" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Search bar -->
        <Border Grid.Row="1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="10" Padding="16" Margin="0,16,0,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Row="0" Grid.Column="0"
                         Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="검색어 입력 (예: react vite, machine learning, awesome-list)"
                         FontSize="14" Padding="8"
                         KeyDown="QueryBox_KeyDown"/>
                <Button Grid.Row="0" Grid.Column="1"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Margin="8,0,0,0" Padding="20,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" Margin="0,0,6,0"/>
                        <TextBlock Text="검색" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="언어:" Opacity="0.6" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Languages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              MaxDropDownHeight="320"/>
                    <TextBlock Grid.Column="2" Text="정렬:" Opacity="0.6" FontSize="12"
                               VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding SortOptions}"
                              SelectedValuePath="Key"
                              DisplayMemberPath="Display"
                              SelectedValue="{Binding SelectedSort}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NotNullToVis}}"
                   Opacity="0.7" FontSize="12" Margin="4,0,0,8"/>

        <!-- Results -->
        <Border Grid.Row="3"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="10" Padding="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1">
            <Grid>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasResults, Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock Text="🔭" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="검색어를 입력하고 찾아보세요"
                               Opacity="0.5" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Results list -->
                <ScrollViewer Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Results}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,12" Margin="6,3"
                                            CornerRadius="8"
                                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar -->
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                                    VerticalAlignment="Top">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>

                                            <!-- Content -->
                                            <StackPanel Grid.Column="1" Margin="12,0">
                                                <TextBlock FontSize="14" FontWeight="SemiBold">
                                                    <Run Text="{Binding Owner, Mode=OneWay}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                    <Run Text=" / "/>
                                                    <Run Text="{Binding Name, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Description}"
                                                           Visibility="{Binding Description, Converter={StaticResource NotNullToVis}}"
                                                           Opacity="0.7" FontSize="12" Margin="0,3,0,0"
                                                           TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <TextBlock Text="⭐" FontSize="11" Margin="0,0,3,0"/>
                                                    <TextBlock Text="{Binding StarsDisplay}" FontSize="11" Margin="0,0,12,0"/>
                                                    <TextBlock Text="🍴" FontSize="11" Margin="0,0,3,0"/>
                                                    <TextBlock Text="{Binding ForksDisplay}" FontSize="11" Margin="0,0,12,0"/>
                                                    <TextBlock Text="{Binding Language}"
                                                               Visibility="{Binding Language, Converter={StaticResource NotNullToVis}}"
                                                               FontSize="11" Margin="0,0,12,0"/>
                                                    <TextBlock Opacity="0.5" FontSize="11">
                                                        <Run Text="updated "/>
                                                        <Run Text="{Binding UpdatedDisplay, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Buttons -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                <Button Command="{Binding DataContext.CloneCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource AccentButtonStyle}"
                                                        Margin="0,0,4,0">
                                                    <TextBlock Text="📥 클론"/>
                                                </Button>
                                                <Button Command="{Binding DataContext.OpenInBrowserCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="GitHub에서 열기">
                                                    <TextBlock Text="🔗"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Load more -->
                        <Button Command="{Binding LoadMoreCommand}"
                                Visibility="{Binding HasMore, Converter={StaticResource BoolToVis}}"
                                Content="더 보기"
                                Margin="6,8,6,12"
                                Height="36"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Busy overlay -->
                <ui:ProgressRing IsActive="{Binding IsBusy}" Width="32" Height="32"
                                 HorizontalAlignment="Center" VerticalAlignment="Top"
                                 Margin="0,16,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
