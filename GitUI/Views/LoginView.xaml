<UserControl x:Class="GitUI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:vm="clr-namespace:GitUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border MaxWidth="460" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="24"
                    Padding="36,32"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="GitUI" FontSize="34" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="GitHub 리포지토리 관리 도구"
                                   Opacity="0.65" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- ============ CHOOSE METHOD ============ -->
                    <StackPanel Visibility="{Binding Panel, Converter={StaticResource EnumToVis}, ConverterParameter=Choose}">

                        <!-- Method 1: OAuth Web Flow (primary, only if Client Secret is configured) -->
                        <Button Command="{Binding LoginWithGithubWebCommand}"
                                IsEnabled="{Binding HasWebFlow}"
                                Style="{StaticResource AccentButtonStyle}"
                                Height="48" Margin="0,0,0,8"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🐙" Margin="0,0,8,0" FontSize="16"/>
                                <TextBlock Text="GitHub 계정으로 로그인" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <TextBlock FontSize="11" Opacity="0.55" Margin="0,0,0,4">
                            <Run Text="브라우저로 한 번에 인증 (Web Flow)"/>
                        </TextBlock>
                        <TextBlock Text="OAuth 설정에서 Client Secret을 추가하세요."
                                   Foreground="#FFB347"
                                   FontSize="11"
                                   Visibility="{Binding HasWebFlow, Converter={StaticResource InverseBoolToVis}}"
                                   Margin="0,0,0,8"/>

                        <!-- Method 2: OAuth Device Flow -->
                        <Button Command="{Binding LoginWithGithubDeviceCommand}"
                                IsEnabled="{Binding HasDeviceFlow}"
                                Height="40" Margin="0,12,0,4"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔑" Margin="0,0,8,0"/>
                                <TextBlock Text="Device 코드로 로그인"/>
                            </StackPanel>
                        </Button>
                        <TextBlock FontSize="11" Opacity="0.55" Margin="0,0,0,4">
                            <Run Text="브라우저에 코드 입력 (Device Flow · Client Secret 불필요)"/>
                        </TextBlock>
                        <TextBlock Text="OAuth 설정에서 Client ID를 추가하세요."
                                   Foreground="#FFB347"
                                   FontSize="11"
                                   Visibility="{Binding HasDeviceFlow, Converter={StaticResource InverseBoolToVis}}"
                                   Margin="0,0,0,4"/>

                        <!-- Divider -->
                        <Grid Margin="0,18,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Height="1" VerticalAlignment="Center"
                                    Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                            <TextBlock Grid.Column="1" Text="또는" Margin="12,0" Opacity="0.5"/>
                            <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                                    Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                        </Grid>

                        <!-- Method 3: PAT -->
                        <TextBlock Text="Personal Access Token" FontSize="12" Opacity="0.7" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="PatBox"
                                     ui:ControlHelper.PlaceholderText="ghp_..."
                                     PasswordChanged="PatBox_PasswordChanged"
                                     Margin="0,0,0,8"/>
                        <Button Command="{Binding LoginWithPatCommand}"
                                Content="토큰으로 로그인"
                                Height="36"
                                HorizontalAlignment="Stretch"/>
                        <TextBlock Margin="0,8,0,0" FontSize="11" Opacity="0.55" TextWrapping="Wrap">
                            <Hyperlink NavigateUri="https://github.com/settings/tokens/new?scopes=repo,delete_repo&amp;description=GitUI"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                새 PAT 발급받기 →
                            </Hyperlink>
                        </TextBlock>

                        <!-- OAuth config link -->
                        <Button Command="{Binding ShowConfigureOAuthCommand}"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0">
                            <TextBlock Text="⚙ OAuth App 설정" FontSize="11" Opacity="0.7"/>
                        </Button>
                    </StackPanel>

                    <!-- ============ DEVICE FLOW PENDING ============ -->
                    <StackPanel Visibility="{Binding Panel, Converter={StaticResource EnumToVis}, ConverterParameter=DeviceFlowPending}">
                        <TextBlock Text="브라우저에서 다음 코드를 입력하세요"
                                   TextAlignment="Center" Opacity="0.7" Margin="0,0,0,12"/>
                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <TextBlock Text="{Binding UserCode}"
                                       FontFamily="Consolas, Courier New"
                                       FontSize="32" FontWeight="Bold"
                                       TextAlignment="Center"/>
                        </Border>
                        <Button Command="{Binding CopyUserCodeCommand}" Content="코드 복사"
                                Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                        <Button Command="{Binding OpenVerificationUrlCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Content="브라우저에서 인증하기"
                                Margin="0,0,0,12" HorizontalAlignment="Stretch"/>
                        <ui:ProgressRing IsActive="True" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="인증 대기 중..."
                                   TextAlignment="Center" Opacity="0.5" Margin="0,8,0,0" FontSize="12"/>
                        <Button Command="{Binding CancelPendingCommand}"
                                Content="취소"
                                Margin="0,16,0,0"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- ============ WEB FLOW PENDING ============ -->
                    <StackPanel Visibility="{Binding Panel, Converter={StaticResource EnumToVis}, ConverterParameter=WebFlowPending}"
                                HorizontalAlignment="Center">
                        <TextBlock Text="🐙" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="브라우저에서 GitHub 인증을 완료하세요"
                                   TextAlignment="Center" FontSize="14" Margin="0,0,0,16"/>
                        <ui:ProgressRing IsActive="True" Width="32" Height="32" HorizontalAlignment="Center"/>
                        <TextBlock Text="앱이 자동으로 인증을 받습니다..."
                                   TextAlignment="Center" Opacity="0.5" Margin="0,12,0,0" FontSize="12"/>
                        <Button Command="{Binding CancelPendingCommand}"
                                Content="취소"
                                Margin="0,20,0,0"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- ============ CONFIGURE OAUTH ============ -->
                    <StackPanel Visibility="{Binding Panel, Converter={StaticResource EnumToVis}, ConverterParameter=ConfigureOAuth}">
                        <TextBlock Text="GitHub OAuth App 설정"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12" Margin="0,0,0,12">
                            <Run Text="GitHub로 한 번 OAuth App을 만들어두면 두 가지 방식 모두 사용 가능합니다."/>
                            <LineBreak/>
                            <Hyperlink NavigateUri="https://github.com/settings/applications/new"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                OAuth App 만들기 →
                            </Hyperlink>
                        </TextBlock>

                        <!-- Callback URL info card -->
                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                CornerRadius="6" Padding="10,8" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock FontSize="11" Opacity="0.7" Text="OAuth App에 입력할 Authorization callback URL:"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding RedirectUri}"
                                               FontFamily="Consolas, Courier New" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Command="{Binding CopyRedirectUriCommand}"
                                            Content="복사" FontSize="11"
                                            Padding="8,2" Margin="8,0,0,0"/>
                                </Grid>
                                <TextBlock FontSize="10" Opacity="0.5" Margin="0,4,0,0"
                                           Text="Device Flow만 쓸 거면 'Enable Device Flow'를 OAuth App 설정에서 체크하세요."/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Client ID *" Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ClientIdInput, UpdateSourceTrigger=PropertyChanged}"
                                 ui:ControlHelper.PlaceholderText="Iv1.xxxxxxxxxxxxxxxx"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Client Secret (Web Flow에 필요, Device Flow는 불필요)"
                                   Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="ClientSecretBox"
                                     ui:ControlHelper.PlaceholderText="(선택) ghs_..."
                                     PasswordChanged="ClientSecretBox_PasswordChanged"
                                     Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{Binding BackToChooseCommand}"
                                    Content="뒤로" Margin="0,0,4,0" Height="36"/>
                            <Button Grid.Column="1" Command="{Binding SaveOAuthConfigCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Content="저장" Margin="4,0,0,0" Height="36"/>
                        </Grid>
                    </StackPanel>

                    <!-- Status -->
                    <TextBlock Text="{Binding StatusMessage}"
                               Visibility="{Binding StatusMessage, Converter={StaticResource NotNullToVis}}"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextAlignment="Center" Margin="0,16,0,0"
                               FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
