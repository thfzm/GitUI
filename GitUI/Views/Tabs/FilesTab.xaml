<UserControl x:Class="GitUI.Views.Tabs.FilesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:vm="clr-namespace:GitUI.ViewModels.Tabs"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:FilesTabViewModel}"
             mc:Ignorable="d">
    <Grid Margin="0,16,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="파일 브라우저"
                       FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Command="{Binding LoadTreeCommand}"
                    Content="새로고침" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Command="{Binding DownloadRepoZipCommand}"
                    Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📦" Margin="0,0,6,0"/>
                    <TextBlock Text="전체 ZIP 다운로드"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Tree + Preview split -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tree -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="10" Padding="0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1">
                <TreeView x:Name="FileTree"
                          ItemsSource="{Binding RootNodes}"
                          BorderThickness="0" Background="Transparent"
                          SelectedItemChanged="FileTree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" FontSize="13"/>
                                <TextBlock Text="{Binding Name}" FontSize="13"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- Preview -->
            <Border Grid.Column="2"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="10" Padding="0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Preview header -->
                    <Border Grid.Row="0" Padding="14,10"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding SelectedNode.Path}"
                                           FontFamily="Consolas, Courier New" FontSize="12"
                                           Opacity="0.85" TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontSize="10" Opacity="0.5">
                                    <Run Text="{Binding SelectedNode.IsFolder, Converter={StaticResource BoolToFolderFile}, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding DownloadFileCommand}"
                                    ToolTip="이 파일 다운로드"
                                    Margin="0,0,4,0"
                                    Visibility="{Binding SelectedNode, Converter={StaticResource NotNullToVis}}"
                                    IsEnabled="{Binding SelectedNode.IsFolder, Converter={StaticResource InverseBoolEnableConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬇"/>
                                    <TextBlock Text=" 파일"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2"
                                    Command="{Binding DownloadFolderCommand}"
                                    ToolTip="이 폴더 ZIP으로 다운로드"
                                    Visibility="{Binding SelectedNode, Converter={StaticResource NotNullToVis}}"
                                    IsEnabled="{Binding SelectedNode.IsFolder}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦"/>
                                    <TextBlock Text=" 폴더 ZIP"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Preview body -->
                    <Grid Grid.Row="1">
                        <!-- Empty state -->
                        <TextBlock Text="좌측에서 파일을 선택하세요"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Opacity="0.4"
                                   Visibility="{Binding SelectedNode, Converter={StaticResource NullToVis}}"/>

                        <!-- Binary file -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsPreviewBinary, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="🔒" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding PreviewInfo}"
                                       Opacity="0.6" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Text preview -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Visibility="{Binding PreviewText, Converter={StaticResource NotNullToVis}}">
                            <TextBox Text="{Binding PreviewText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas, Courier New" FontSize="12"
                                     BorderThickness="0" Background="Transparent"
                                     TextWrapping="NoWrap"
                                     Padding="14"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NotNullToVis}}"
                   Margin="0,12,0,0" Opacity="0.75" FontSize="12"/>
    </Grid>
</UserControl>
