<UserControl x:Class="GitUI.Views.Tabs.UploadTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:vm="clr-namespace:GitUI.ViewModels.Tabs"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:UploadTabViewModel}"
             mc:Ignorable="d"
             Focusable="True"
             KeyDown="OnKeyDown">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,0">
        <StackPanel>
            <!-- Commit message + path + gitignore toggle -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="10" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="커밋 메시지" Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Text="대상 경로 (리포 내부, 비워두면 루트)" Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding TargetSubpath, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="예: assets/images" Margin="0,0,0,12"/>

                    <CheckBox IsChecked="{Binding RespectGitignore}"
                              Content="로컬 .gitignore 적용 (제외 패턴 따르기)"/>
                </StackPanel>
            </Border>

            <!-- Drop zone -->
            <Border x:Name="DropZone"
                    AllowDrop="True"
                    Drop="DropZone_Drop"
                    DragEnter="DropZone_DragEnter"
                    DragLeave="DropZone_DragLeave"
                    DragOver="DropZone_DragOver"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource SystemAccentColorLight2Brush}"
                    BorderThickness="2"
                    CornerRadius="10"
                    Padding="32" MinHeight="160" Margin="0,0,0,16">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📂" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="여기에 파일이나 폴더를 드래그&amp;드롭"
                               FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="또는 Ctrl+V로 클립보드 이미지 업로드"
                               Opacity="0.55" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Folder sync section -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="10" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="폴더 동기화" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="선택한 폴더의 모든 파일을 리포지토리로 업로드합니다."
                               Opacity="0.6" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SelectedFolder, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"
                                 ui:ControlHelper.PlaceholderText="폴더가 선택되지 않음"/>
                        <Button Grid.Column="1" Command="{Binding PickFolderCommand}"
                                Content="폴더 선택" Margin="8,0,0,0"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding PreviewSyncCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Margin="0,0,4,0" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" Margin="0,0,8,0"/>
                                <TextBlock Text="미리보기 후 동기화"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Command="{Binding SyncFolderCommand}"
                                Margin="4,0,0,0" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔄" Margin="0,0,8,0"/>
                                <TextBlock Text="바로 동기화"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Progress -->
            <Border Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="{Binding ProgressLabel}" FontSize="12" Opacity="0.8" Margin="0,0,0,6"/>
                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NotNullToVis}}"
                       Margin="0,12,0,0" TextWrapping="Wrap" Opacity="0.75" FontSize="12"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
