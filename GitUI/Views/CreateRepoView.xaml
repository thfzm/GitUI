<UserControl x:Class="GitUI.Views.CreateRepoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:vm="clr-namespace:GitUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:CreateRepoViewModel}"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel MaxWidth="640" HorizontalAlignment="Stretch">
            <TextBlock Text="새 리포지토리"
                       FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="GitHub에 새로운 리포지토리를 만듭니다."
                       Opacity="0.6" Margin="0,0,0,28"/>

            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="10" Padding="24"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="이름 *" Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="my-awesome-repo"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="설명" Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="(선택) 한 줄 설명"
                             Margin="0,0,0,16"/>

                    <!-- Project starter template -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="프로젝트 스타터" Opacity="0.75" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="언어별 시작 파일 자동 생성" Opacity="0.5" FontSize="10" VerticalAlignment="Center"/>
                    </Grid>
                    <ComboBox ItemsSource="{Binding ProjectTemplateOptions}"
                              SelectedItem="{Binding SelectedProjectTemplate}"
                              DisplayMemberPath="DisplayName"
                              HorizontalAlignment="Stretch"
                              Margin="0,4,0,16"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text=".gitignore 템플릿" Opacity="0.75" FontSize="12"/>
                                <ui:ProgressRing Grid.Column="1"
                                                 IsActive="True" Width="12" Height="12"
                                                 Visibility="{Binding TemplatesLoaded, Converter={StaticResource InverseBoolToVis}}"/>
                            </Grid>
                            <ComboBox ItemsSource="{Binding GitignoreTemplates}"
                                      SelectedItem="{Binding GitignoreTemplate}"
                                      HorizontalAlignment="Stretch"
                                      MaxDropDownHeight="320"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="라이선스" Opacity="0.75" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Licenses}"
                                      SelectedItem="{Binding SelectedLicense}"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch"
                                      MaxDropDownHeight="320"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="비공개 리포지토리 (Private)"
                              IsChecked="{Binding IsPrivate}"
                              Margin="0,0,0,8"/>
                    <CheckBox Content="README로 자동 초기화 (권장)"
                              IsChecked="{Binding AutoInit}"
                              Margin="0,0,0,16"/>

                    <Button Command="{Binding CreateCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Height="40" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <ui:ProgressRing IsActive="{Binding IsBusy}"
                                             Width="16" Height="16" Margin="0,0,8,0"
                                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="리포지토리 만들기" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- Progress for starter file uploads -->
                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding ProgressLabel, Converter={StaticResource NotNullToVis}}">
                        <TextBlock Text="{Binding ProgressLabel}" FontSize="11" Opacity="0.75" Margin="0,0,0,4"/>
                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}"
                               Visibility="{Binding StatusMessage, Converter={StaticResource NotNullToVis}}"
                               Margin="0,12,0,0" TextWrapping="Wrap" Opacity="0.75" FontSize="12"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
